# scalper-v2 environment template.
#
# Copy to .env (local dev) or install at /etc/scalper-v2/secrets.env on the
# server. Never commit a populated .env file. Production secrets are mode 600,
# owned by the service user, loaded by compose via env_file (see brief §16.1,
# §18.1).
#
# Tags:
#   # F0: used now (scaffold / hello-world service).
#   # F2: populated when exchange adapters land (T-F2-*).
#   # F5: populated when alerting-svc lands.
#
# -----------------------------------------------------------------------------
# Core service env (F0)
# -----------------------------------------------------------------------------

# Per-service identifier; propagated into structured logs (brief §5.7).
SERVICE_NAME=signal-gateway

# structlog level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# NATS JetStream message bus — internal-only per §16.6. Services
# resolve `nats` by service name inside the compose backend
# network; no auth, no secrets. Host-side tooling (CLI smoke
# tests from the dev laptop) uses the dev-overlay's
# 127.0.0.1:4222 publish directly, not this env var.
NATS_URL=nats://nats:4222

# -----------------------------------------------------------------------------
# PostgreSQL / TimescaleDB (F0)
# -----------------------------------------------------------------------------

# PostgreSQL credentials.
#
# POSTGRES_USER and POSTGRES_DB are read by both compose.yaml and
# compose.dev.yaml via the services.postgres.environment block.
POSTGRES_USER=scalper
POSTGRES_DB=scalper

# Password handling differs between prod and dev:
#
#   * Prod (compose.yaml):     POSTGRES_PASSWORD_FILE is hardcoded in
#     the compose file to `/run/secrets/pg_password`, populated via
#     Docker secret from `/etc/scalper-v2/pg_password` on the host.
#     Neither variable below is consulted.
#
#   * Dev  (compose.dev.yaml): POSTGRES_PASSWORD below is read inline
#     and passed to the postgres container. Leave the placeholder or
#     change to a stronger value; never commit a real secret.
POSTGRES_PASSWORD=change-me-dev-only

# asyncpg DSN. signal-gateway (T-015a) reads this directly via Pydantic
# Settings at startup (§5.11) — no client-side assembly from
# POSTGRES_USER/PASSWORD. In prod, placed at /etc/scalper-v2/secrets.env
# and loaded via compose env_file; in dev, read from this file by
# compose.dev.yaml's `environment:` overrides (see signal-gateway
# overlay block).
DATABASE_URL=postgresql://scalper:change-me-dev-only@postgres:5432/scalper

# Alembic CLI DSN — read by migrations/env.py (brief §N8, §7.4). Required
# to run `uv run alembic -c migrations/alembic.ini upgrade head` on a dev
# host. In production the one-shot migrate container (deferred to T-018)
# injects this separately; never commit a populated value.
# POSTGRES_URL=postgresql://scalper:change-me-dev-only@127.0.0.1:5432/scalper

# Migration integration-test DSN — read by the fixture in
# `tests/integration/migrations/conftest.py`. If unset, migration tests
# skip (T-010: CI-fast ignores tests/integration wholesale; T-016 wires
# testcontainers to set this for CI-full). Should point at a database
# where the test role has CREATEDB privilege, because the fixture spins
# up and drops a throwaway DB per test run.
# POSTGRES_TEST_DSN=postgresql://scalper:change-me-dev-only@127.0.0.1:5432/scalper

# -----------------------------------------------------------------------------
# Signal ingest (F0 hello-world uses a single shared secret; per-bot HMAC
# arrives in T-F1 with the full signal-gateway).
# -----------------------------------------------------------------------------

# HMAC-SHA256 key used by signal-gateway to authenticate TradingView webhooks.
SIGNAL_GATEWAY_HMAC_SECRET=replace-me

# -----------------------------------------------------------------------------
# Per-bot live-trading safety gate (brief §16, §18.1). Must be exactly "yes"
# for a bot started with exchange.mode: live; any other value keeps it dry.
# Strategy engines read these; see compose.yaml.
# -----------------------------------------------------------------------------

BOT_ALPHA_CONFIRM_LIVE=no
BOT_BETA_CONFIRM_LIVE=no

# -----------------------------------------------------------------------------
# Bybit API credentials per bot. Populated in F2 when execution-service lands.
# -----------------------------------------------------------------------------

# F2: BOT_ALPHA_BYBIT_API_KEY=
# F2: BOT_ALPHA_BYBIT_API_SECRET=
# F2: BOT_BETA_BYBIT_API_KEY=
# F2: BOT_BETA_BYBIT_API_SECRET=

# -----------------------------------------------------------------------------
# Telegram alerting (F5 alerting-svc).
# -----------------------------------------------------------------------------

# F5: TELEGRAM_BOT_TOKEN=
# F5: TELEGRAM_CHAT_SYSTEM=
# F5: TELEGRAM_CHAT_TRADING=
# F5: TELEGRAM_CHAT_PNL=
# F5: TELEGRAM_CHAT_SECURITY=

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (F0 compose, T-014). Loaded from
# /etc/scalper-v2/cloudflared.env on the prod host (the compose service
# declares env_file: required: false, so dev hosts without that file still
# render `docker compose config` cleanly). Dev hosts omit the cloudflared
# service from `docker compose up -d <selection>` entirely. See
# infra/cloudflared/README.md for tunnel creation + token install.
# -----------------------------------------------------------------------------

# TUNNEL_TOKEN=
