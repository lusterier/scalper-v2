# scalper-v2 environment template.
#
# Copy to .env (local dev) or install at /etc/scalper-v2/secrets.env on the
# server. Never commit a populated .env file. Production secrets are mode 600,
# owned by the service user, loaded by compose via env_file (see brief §16.1,
# §18.1).
#
# Tags:
#   # F0: used now (scaffold / hello-world service).
#   # F2: populated when exchange adapters land (T-F2-*).
#   # F5: populated when alerting-svc lands.
#
# -----------------------------------------------------------------------------
# Core service env (F0)
# -----------------------------------------------------------------------------

# Per-service identifier; propagated into structured logs (brief §5.7).
SERVICE_NAME=signal-gateway

# structlog level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# NATS JetStream endpoint. Compose service name in production.
NATS_URL=nats://nats:4222

# -----------------------------------------------------------------------------
# PostgreSQL / TimescaleDB (F0)
# -----------------------------------------------------------------------------

POSTGRES_USER=scalper
POSTGRES_DB=scalper

# Production uses a docker secret mounted into the container; dev may use an
# inline POSTGRES_PASSWORD instead. Set exactly one.
POSTGRES_PASSWORD_FILE=/run/secrets/pg_password
# POSTGRES_PASSWORD=change-me-dev-only

# asyncpg DSN assembled by each service at startup from the above.
# Provided here for single-container / test scenarios.
# DATABASE_URL=postgresql://scalper:change-me-dev-only@postgres:5432/scalper

# -----------------------------------------------------------------------------
# Signal ingest (F0 hello-world uses a single shared secret; per-bot HMAC
# arrives in T-F1 with the full signal-gateway).
# -----------------------------------------------------------------------------

# HMAC-SHA256 key used by signal-gateway to authenticate TradingView webhooks.
SIGNAL_GATEWAY_HMAC_SECRET=replace-me

# -----------------------------------------------------------------------------
# Per-bot live-trading safety gate (brief §16, §18.1). Must be exactly "yes"
# for a bot started with exchange.mode: live; any other value keeps it dry.
# Strategy engines read these; see compose.yaml.
# -----------------------------------------------------------------------------

BOT_ALPHA_CONFIRM_LIVE=no
BOT_BETA_CONFIRM_LIVE=no

# -----------------------------------------------------------------------------
# Bybit API credentials per bot. Populated in F2 when execution-service lands.
# -----------------------------------------------------------------------------

# F2: BOT_ALPHA_BYBIT_API_KEY=
# F2: BOT_ALPHA_BYBIT_API_SECRET=
# F2: BOT_BETA_BYBIT_API_KEY=
# F2: BOT_BETA_BYBIT_API_SECRET=

# -----------------------------------------------------------------------------
# Telegram alerting (F5 alerting-svc).
# -----------------------------------------------------------------------------

# F5: TELEGRAM_BOT_TOKEN=
# F5: TELEGRAM_CHAT_SYSTEM=
# F5: TELEGRAM_CHAT_TRADING=
# F5: TELEGRAM_CHAT_PNL=
# F5: TELEGRAM_CHAT_SECURITY=

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (F0 compose, T-014). Loaded via cloudflared.env file on
# the server; replicated here for documentation.
# -----------------------------------------------------------------------------

# TUNNEL_TOKEN=
