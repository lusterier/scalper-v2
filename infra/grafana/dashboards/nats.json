{
  "schemaVersion": 41,
  "uid": "scalper-v2-nats",
  "title": "scalper-v2 NATS",
  "tags": ["scalper-v2", "ops", "nats"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total consumer pending",
      "description": "Empty until F5+ prometheus-nats-exporter sidecar lands. Sums nats_consumer_pending across all consumers.",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "sum(nats_consumer_pending)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Consumer pending by consumer",
      "description": "Empty until F5+ prometheus-nats-exporter sidecar lands. Per BRIEF §15.4:2156 nats_consumer_pending{consumer}.",
      "gridPos": {"h": 9, "w": 16, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "nats_consumer_pending",
          "legendFormat": "{{consumer}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 0}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Stream message count (total)",
      "description": "Empty until F5+ prometheus-nats-exporter sidecar lands.",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "sum(nats_stream_total_messages)",
          "instant": true
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 0}, "overrides": []}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Stream bytes by stream",
      "description": "Empty until F5+ prometheus-nats-exporter sidecar lands. Stream sizes per stream (8 streams: market_ticks/market_ohlc/signals/orders/trading_events/audit/features/alerts per infra/nats/streams/).",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "nats_stream_total_bytes",
          "legendFormat": "{{stream}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    }
  ]
}
