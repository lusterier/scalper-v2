{
  "schemaVersion": 41,
  "uid": "scalper-v2-pg",
  "title": "scalper-v2 PostgreSQL",
  "tags": ["scalper-v2", "ops", "pg"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "DB pool saturation by service",
      "description": "Per BRIEF §15.3 db_pool_saturation{service} — emitted by services when their asyncpg.Pool reports utilization. Empty until services emit (no service currently wired).",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "db_pool_saturation",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Postgres active connections",
      "description": "Empty until F5+ postgres_exporter sidecar lands. pg_stat_database_numbackends per database.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 0}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Slow queries (>1s) last 5m",
      "description": "Empty until F5+ postgres_exporter sidecar lands. Sum of pg_stat_statements_slow_query_count rate.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "sum(rate(pg_stat_statements_slow_query_count[5m]))",
          "instant": true
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 2}, "overrides": []}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Replication lag (max seconds)",
      "description": "Empty until F5+ postgres_exporter sidecar lands AND replication is configured. pg_stat_replication_lag_seconds.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "max(pg_stat_replication_lag_seconds)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 30}
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
