{
  "schemaVersion": 41,
  "uid": "scalper-v2-host",
  "title": "scalper-v2 Host",
  "tags": ["scalper-v2", "ops", "host"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU usage %",
      "description": "Empty until F5+ node-exporter sidecar lands. Computed as 100 - idle-rate per instance.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory available (bytes)",
      "description": "Empty until F5+ node-exporter sidecar lands. node_memory_MemAvailable_bytes per instance.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Disk usage % per mount",
      "description": "Empty until F5+ node-exporter sidecar lands. Computed as (1 - avail/size) per filesystem mountpoint.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "100 - (node_filesystem_avail_bytes / node_filesystem_size_bytes * 100)",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network receive bytes/sec",
      "description": "Empty until F5+ node-exporter sidecar lands. node_network_receive_bytes_total rate per network device.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ds_prom"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "ds_prom"},
          "expr": "rate(node_network_receive_bytes_total[1m])",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}, "overrides": []}
    }
  ]
}
